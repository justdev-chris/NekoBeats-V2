  "Tut1Title": "\u5165\u95E8\u6307\u5357",
  "Tut1Content": "1.\u901A\u8FC7\u626C\u58F0\u5668\u6216\u8033\u673A\u64AD\u653E\u97F3\u4E50\u3002\n\n2. NekoBeats\u81EA\u52A8\u6355\u83B7\u60A8\u7684\u7CFB\u7EDF\u97F3\u9891\u2014\u65E0\u9700\u8BBE\u7F6E\uFF01\n\n3.\u6D6E\u52A8\u680F\u5C06\u663E\u793A\u5728\u5C4F\u5E55\u4E0A\uFF0C\u5B9E\u65F6\u5BF9\u97F3\u4E50\u505A\u51FA\u53CD\u5E94\u3002\n\n4.\u63A7\u5236\u9762\u677F\u5141\u8BB8\u60A8\u81EA\u5B9A\u4E49\u6240\u6709\u5185\u5BB9\u2014\u989C\u8272\u3001\u6761\u6570\u3001\u9AD8\u5EA6\u3001\u6548\u679C\u7B49\u3002",
  "Tut2Title": "\u5B9A\u5236\u5316",
  "Tip1": "VIZ\u9009\u9879\u5361\u2014\u8C03\u6574\u6761\u6570\u3001\u9AD8\u5EA6\u3001\u4E0D\u900F\u660E\u5EA6\u548C\u95F4\u8DDD",
  "Tip2": "\u989C\u8272\u9009\u9879\u5361\u2014\u9009\u62E9\u680F\u989C\u8272\uFF0C\u542F\u7528\u5F69\u8679\u6216\u6E10\u53D8",
  "Tip3": "\u7279\u6548\u9009\u9879\u5361\u2014\u7EFD\u653E\u3001\u7C92\u5B50\u3001\u5706\u5708\u6A21\u5F0F\u3001\u6DE1\u5165\u6DE1\u51FA\u6548\u679C",
  "Tip4": "\u97F3\u9891\u9009\u9879\u5361\u2014\u7075\u654F\u5EA6\u3001\u5E73\u6ED1\u901F\u5EA6\u3001\u5EF6\u8FDF\u8865\u507F",
