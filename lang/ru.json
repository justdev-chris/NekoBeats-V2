{
  "WindowTitle": "NekoBeats Control",
  "VisualizerTitle": "NekoBeats V2.3.4",
  "WelcomeTitle": "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 NekoBeats! \uD83D\uDC31",
  "WelcomeDesc": "\u0413\u043B\u0430\u0434\u043A\u0438\u0439 \u0430\u0443\u0434\u0438\u043E\u0432\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0432\u0430\u0448\u0443 \u043C\u0443\u0437\u044B\u043A\u0443\n\u0432 \u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0438\u0435 \u0441\u0432\u0435\u0442\u043E\u0432\u044B\u0435 \u043F\u043E\u043B\u043E\u0441\u044B.",
  "WelcomeSetup": "\u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u043D\u0430\u0441\u0442\u0440\u043E\u0438\u043C \u0432\u0430\u0441.",
  "Tut1Title": "\u041D\u0430\u0447\u0430\u043B\u043E \u0440\u0430\u0431\u043E\u0442\u044B",
  "Tut1Content": "1. \u0412\u043E\u0441\u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0438\u0442\u0435 \u043C\u0443\u0437\u044B\u043A\u0443 \u0447\u0435\u0440\u0435\u0437 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438 \u0438\u043B\u0438 \u043D\u0430\u0443\u0448\u043D\u0438\u043A\u0438.\n\n2. NekoBeats \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u044B\u0439 \u0437\u0432\u0443\u043A \u2014 \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430 \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F!\n\n3. \u041D\u0430 \u044D\u043A\u0440\u0430\u043D\u0435 \u043F\u043E\u044F\u0432\u044F\u0442\u0441\u044F \u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0438\u0435 \u043F\u043E\u043B\u043E\u0441\u044B, \u0440\u0435\u0430\u0433\u0438\u0440\u0443\u044E\u0449\u0438\u0435 \u043D\u0430 \u043C\u0443\u0437\u044B\u043A\u0443 \u0432 \u0440\u0435\u0436\u0438\u043C\u0435 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.\n\n4. \u041F\u0430\u043D\u0435\u043B\u044C \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u043D\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0442\u044C \u0432\u0441\u0435 \u2014 \u0446\u0432\u0435\u0442\u0430, \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u043F\u043E\u043B\u043E\u0441, \u0432\u044B\u0441\u043E\u0442\u0443, \u044D\u0444\u0444\u0435\u043A\u0442\u044B \u0438 \u043C\u043D\u043E\u0433\u043E\u0435 \u0434\u0440\u0443\u0433\u043E\u0435.",
  "Tut2Title": "\u041F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430",
  "Tip1": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 VIZ \u2014 \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u043F\u043E\u043B\u043E\u0441, \u0432\u044B\u0441\u043E\u0442\u044B, \u043D\u0435\u043F\u0440\u043E\u0437\u0440\u0430\u0447\u043D\u043E\u0441\u0442\u0438 \u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F",
  "Tip2": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 COLORS (\u0426\u0412\u0415\u0422\u0410) \u2014 \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0446\u0432\u0435\u0442\u0430 \u043F\u0430\u043D\u0435\u043B\u0438, \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u0435 \u0440\u0430\u0434\u0443\u0433\u0443 \u0438\u043B\u0438 \u0433\u0440\u0430\u0434\u0438\u0435\u043D\u0442",
  "Tip3": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 FX \u2014 \u0446\u0432\u0435\u0442\u0435\u043D\u0438\u0435, \u0447\u0430\u0441\u0442\u0438\u0446\u044B, \u0440\u0435\u0436\u0438\u043C \u043A\u0440\u0443\u0433\u0430, \u044D\u0444\u0444\u0435\u043A\u0442 \u0437\u0430\u0442\u0443\u0445\u0430\u043D\u0438\u044F",
  "Tip4": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 \u00AB\u0410\u0423\u0414\u0418\u041E\u00BB \u2014 \u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C, \u043F\u043B\u0430\u0432\u043D\u0430\u044F \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C, \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u0430",
  "Tip5": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 \u041E\u041A\u041D\u0410 \u2014 \u043F\u0435\u0440\u0435\u0445\u043E\u0434 \u043F\u043E \u0441\u0441\u044B\u043B\u043A\u0435, \u043B\u0438\u043C\u0438\u0442 FPS, \u0432\u044B\u0431\u043E\u0440 \u043C\u043E\u043D\u0438\u0442\u043E\u0440\u0430",
  "Tip6": "\u0412\u043A\u043B\u0430\u0434\u043A\u0430 \u041F\u0420\u0415\u0414\u0423\u0421\u0422\u0410\u041D\u041E\u0412\u041E\u041A \u2014 \u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0430 \u0444\u0430\u0439\u043B\u043E\u0432 \u043F\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A .nbp \u0438 .nbbar",
  "Tut3Title": "\u0421\u043E\u0432\u0435\u0442\u044B \u0438 \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438",
  "Tut3Content": "\u2022 \u0412\u043A\u043B\u044E\u0447\u0438\u0442\u0435 Click-Through, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u043E\u0441\u044B \u043D\u0435 \u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u043C\u044B\u0448\u044C\n\n\u2022 \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435 \u0440\u0435\u0436\u0438\u043C \u043F\u043E\u0442\u043E\u043A\u043E\u0432\u043E\u0439 \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0434\u043B\u044F \u0437\u0430\u0445\u0432\u0430\u0442\u0430 NekoBeats \u0432 OBS\n\n\u2022 \u0417\u043D\u0430\u0447\u043E\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u043E\u0433\u043E \u0442\u0440\u0435\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0442\u044C/\u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C \u043F\u0430\u043D\u0435\u043B\u044C \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F\n\n\u2022 \u041F\u0440\u043E\u0432\u0435\u0440\u044F\u0439\u0442\u0435 \u043D\u0430\u043B\u0438\u0447\u0438\u0435 \u043E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0439 \u0432 \u043B\u044E\u0431\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u0435\u043D\u044E \u0437\u043D\u0430\u0447\u043A\u043E\u0432 \u0432 \u0442\u0440\u0435\u0435\n\n\u2022 \u041F\u043E\u0434\u0435\u043B\u0438\u0442\u0435\u0441\u044C \u0441\u0432\u043E\u0438\u043C\u0438 \u043F\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430\u043C\u0438 \u043D\u0430 \u0441\u0430\u0439\u0442\u0435 catsdevs.online/NekoBeats-V2/community-themes.html",
